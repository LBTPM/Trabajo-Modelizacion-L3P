# Archivo de datos y parametros del problema de las alcachofas
param H := 50;

set PRODUCTOS := P1, P2, P3, P4;
set CLIENTES := C1, C2, C3, C4, C5;
set ETAPAS:= E1, E2, E3, E4, E5, E6;
param CantAlcach := 2000000; 

param RatioMax:
        E1  E2  E3  E4  E5  E6 :=
P1      2   1   3   1   2   1
P2      1   2   2   3   1   2
P3      2   1   2   2   3   1
P4      1   3   1   2   2   2 ;

param DemandaMin:
        C1  C2  C3  C4  C5 :=
P1      2   1   0   1   0
P2      1   2   1   0   1
P3      0   1   2   1   0
P4      1   0   1   2   1 ;

param DemandaMax:
        C1  C2  C3  C4  C5 :=
P1      60   50   40   50   40
P2      50   60   50   40   50
P3      40   50   60   50   40
P4      50   40   50   60   50  ;     

param Precio: #Precio de venta
